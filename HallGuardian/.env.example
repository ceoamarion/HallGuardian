# Backend environment variables
# Copy this file to .env and fill in real values
# NEVER commit .env to git

# Server port (Railway / Render auto-set $PORT — leave as-is)
PORT=4000

# SQLite database file path
# Local:      hallguardian.db
# Railway:    /data/hallguardian.db   (persistent volume must be mounted at /data)
# Render:     /var/data/hallguardian.db
DB_FILE=hallguardian.db

# JWT signing secret — generate a strong random string, e.g.:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_to_a_64_char_random_hex_string

# Bcrypt cost factor (10-12 is fine for production)
SALT_ROUNDS=10

# Comma-separated list of allowed CORS origins
# Local:      http://localhost:3000,http://localhost:5173
# Production: https://hallguardian.com,https://www.hallguardian.com
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Node environment
NODE_ENV=production
